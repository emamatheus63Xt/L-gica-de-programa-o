programa {
  funcao inicio() {
    inteiro numeros[5]

    escreva("Índice 0: ")
    leia(numeros[0])

    escreva("Índice 1: ")
    leia(numeros[1])

    escreva("Índice 2: ")
    leia(numeros[2])

    numeros[3] = 40
    numeros[4] = 50

    escreva(numeros[0], "\n")
    escreva(numeros[1], "\n")
    escreva(numeros[2], "\n")
    escreva(numeros[3], "\n")
    escreva(numeros[4], "\n")
  }
}
