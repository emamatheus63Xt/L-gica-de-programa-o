programa {
  funcao inicio() {
    real salario
    const real salarioAlto = 1500

    escreva("Informe seu salario: ")
    leia(salario)

    se(salario > salarioAlto)
    escreva("Salário acima da média.")

    se( salario < salarioAlto) {
      escreva("Salário abaixo da média")
    }
    }
  }
}
